---
import SiteLayout from "../layouts/SiteLayout.astro";
import NewsletterForm from "../components/NewsletterForm.astro";
import ProjectCard from "../components/ProjectCard.astro";

const pageTitle = "Projects | Dr. Bhargava R";
const pageDescription =
  "A curated set of project previews for AI, technology education, and training delivery. Subscribe to get weekly insights on building effective learning experiences.";

const projectList = [
  {
    title: "AI in Education: Curriculum Playbook",
    description:
      "A curriculum playbook that breaks AI concepts into practical lessons, activities, and assessment prompts for educators.",
  },
  {
    title: "Tech Training Delivery: Cohort Toolkit",
    description:
      "A cohort toolkit for workshop delivery: lab worksheets, facilitator notes, and outcome tracking templates.",
  },
  {
    title: "Teaching with Modern Web Technologies",
    description:
      "A project-based learning path for modern web skills with guided checkpoints and hands-on practice.",
  },
  {
    title: "Applied Data Literacy for Learners",
    description:
      "Classroom-ready activities that help learners reason with data responsibly—bias-aware prompts, discussion guides, and reflection exercises.",
  },
  {
    title: "Project-Based Learning: Portfolio Templates",
    description:
      "Portfolio templates designed to support project-based learning, reflection, and measurable learner outcomes.",
  },
  {
    title: "Responsible AI: Classroom Guidelines",
    description:
      "Guidelines and example prompts for responsible AI use in educational settings, with safety and ethics guardrails.",
  },
];
---

<SiteLayout title={pageTitle} description={pageDescription}>
  <section class="mx-auto max-w-[960px] px-6 pb-14 pt-14 md:pb-16">
    <div class="max-w-[70ch]">
      <h1 class="font-heading text-5xl font-bold uppercase leading-tight text-black sm:text-6xl">
        Projects
      </h1>
      <p class="mt-5 font-body text-base leading-relaxed text-black/75 sm:text-lg">
        Below are example projects that represent teaching, training, and technology education work.
        These are placeholders for now, but written to match the professional focus.
      </p>
    </div>

    <div class="mt-10 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {projectList.map((p) => (
        <ProjectCard title={p.title} description={p.description} />
      ))}
    </div>

    <div class="mt-14">
      <NewsletterForm />
    </div>
  </section>
</SiteLayout>

