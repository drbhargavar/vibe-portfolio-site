---
import SiteLayout from "../layouts/SiteLayout.astro";
import NewsletterForm from "../components/NewsletterForm.astro";
import ProjectCard from "../components/ProjectCard.astro";

const pageTitle = "Projects | Dr. Bhargava R";
const pageDescription =
  "A placeholder list of projects for Dr. Bhargava R. Subscribe to get weekly insights on AI, tech, and education.";

const projectList = [
  {
    title: "AI in Education: Curriculum Playbook",
    description:
      "Lorem ipsum placeholder describing an AI teaching framework for educators.",
  },
  {
    title: "Tech Training Delivery: Cohort Toolkit",
    description:
      "Lorem ipsum placeholder for workshop structure, labs, and assessment templates.",
  },
  {
    title: "Teaching with Modern Web Technologies",
    description:
      "Lorem ipsum placeholder outlining a practical learning path for contemporary frontend skills.",
  },
  {
    title: "Applied Data Literacy for Learners",
    description:
      "Lorem ipsum placeholder for classroom-ready data literacy activities and guidance.",
  },
  {
    title: "Project-Based Learning: Portfolio Templates",
    description:
      "Lorem ipsum placeholder with structured templates to encourage real-world outcomes.",
  },
  {
    title: "Responsible AI: Classroom Guidelines",
    description:
      "Lorem ipsum placeholder with safe, classroom-friendly AI usage principles.",
  },
];
---

<SiteLayout title={pageTitle} description={pageDescription}>
  <section class="mx-auto max-w-[960px] px-6 pb-14 pt-14 md:pb-16">
    <div class="max-w-[70ch]">
      <h1 class="font-heading text-5xl font-bold uppercase leading-tight text-black sm:text-6xl">
        Projects
      </h1>
      <p class="mt-5 font-body text-base leading-relaxed text-black/75 sm:text-lg">
        Lorem ipsum placeholder text introducing the project list. Each card is a simple preview
        for later replacement with real work.
      </p>
    </div>

    <div class="mt-10 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {projectList.map((p) => (
        <ProjectCard title={p.title} description={p.description} />
      ))}
    </div>

    <div class="mt-14">
      <NewsletterForm />
    </div>
  </section>
</SiteLayout>

