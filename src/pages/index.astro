---
import SiteLayout from "../layouts/SiteLayout.astro";
import NewsletterForm from "../components/NewsletterForm.astro";

const pageTitle = "Dr. Bhargava R | Portfolio";
const pageDescription =
  "Professor / Training Manager / Technology Educator. Learn about Dr. Bhargava R and join the weekly newsletter.";
---

<SiteLayout title={pageTitle} description={pageDescription}>
  <section class="mx-auto max-w-[960px] px-6 pb-8 pt-14 md:pb-12 md:pt-16">
    <div class="grid gap-10 lg:grid-cols-[1.2fr_0.8fr] lg:items-start">
      <div>
        <p class="font-body text-sm font-semibold uppercase tracking-[0.18em] text-black/70">
          Professor / Training Manager / Technology Educator
        </p>

        <h1 class="font-heading text-5xl font-bold uppercase leading-[1.02] text-black sm:text-6xl">
          Dr. Bhargava R
        </h1>

        <p class="mt-5 max-w-[60ch] font-body text-base leading-relaxed text-black/80 sm:text-lg">
          A clean, bold academic voice helping learners connect AI, technology education,
          and practical outcomes.
        </p>

        <div class="mt-7 flex flex-wrap items-center gap-4">
          <a
            href="/projects"
            class="inline-flex items-center justify-center rounded-md bg-accent px-5 py-3 font-body text-sm font-bold uppercase tracking-wide text-white hover:opacity-90"
          >
            View Projects
          </a>
        </div>

        <div class="mt-10 grid gap-4 sm:grid-cols-3">
          <div class="rounded-xl border border-black/10 bg-white p-4">
            <p class="font-heading text-sm font-bold uppercase tracking-wide text-accent">
              Teaching
            </p>
            <p class="mt-2 font-body text-sm text-black/70">
              Curriculum modules and assessments that make AI literacy easy to teach.
            </p>
          </div>
          <div class="rounded-xl border border-black/10 bg-white p-4">
            <p class="font-heading text-sm font-bold uppercase tracking-wide text-accent">
              Training
            </p>
            <p class="mt-2 font-body text-sm text-black/70">
              Workshop structures, lab exercises, and cohort coaching focused on real outcomes.
            </p>
          </div>
          <div class="rounded-xl border border-black/10 bg-white p-4">
            <p class="font-heading text-sm font-bold uppercase tracking-wide text-accent">
              Technology
            </p>
            <p class="mt-2 font-body text-sm text-black/70">
              Applied, project-based learning paths that build confidence with modern tools.
            </p>
          </div>
        </div>
      </div>

      <aside class="lg:pt-2">
        <div class="rounded-2xl border border-black/10 bg-white p-6">
          <h2 class="font-heading text-xl font-bold uppercase tracking-wide text-black">
            Weekly Insights
          </h2>
          <p class="mt-3 font-body text-sm leading-relaxed text-black/70">
            Short, practical notes you can use immediately—AI concepts for educators, training tactics, and tech-ready learning activities.
          </p>
          <div class="mt-5">
            <a
              href="#newsletter"
              class="inline-flex items-center justify-center rounded-md border border-accent px-5 py-3 font-body text-sm font-bold uppercase tracking-wide text-accent hover:bg-accent hover:text-white"
            >
              Subscribe below
            </a>
          </div>
        </div>
      </aside>
    </div>
  </section>

  <NewsletterForm />

  <section class="mx-auto max-w-[960px] px-6 pb-14">
    <div class="rounded-2xl border border-black/10 bg-white p-6 md:p-10">
      <h2 class="font-heading text-2xl font-bold uppercase tracking-wide text-black">
        A short introduction
      </h2>
      <p class="mt-4 max-w-[70ch] font-body text-base leading-relaxed text-black/70">
        I help educators and teams turn complex topics into clear curricula, guided labs, and responsible technology practices.
        Subscribe for weekly insights on teaching AI, delivering effective training, and strengthening learner confidence.
      </p>
    </div>
  </section>
</SiteLayout>

