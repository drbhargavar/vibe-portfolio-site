---
const { title, description } = Astro.props as {
  title: string;
  description: string;
};
---

<article class="rounded-xl border border-black/10 bg-white p-6">
  <h3 class="font-heading text-xl font-bold uppercase tracking-wide text-black">
    {title}
  </h3>
  <p class="mt-3 font-body text-sm leading-relaxed text-black/70">
    {description}
  </p>
</article>

