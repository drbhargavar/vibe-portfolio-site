---
const placeholderEmail = "you@example.com";
---

<section
  id="newsletter"
  aria-labelledby="newsletter-title"
  class="mx-auto w-full max-w-[960px] px-6 py-12 md:py-16"
>
  <div class="rounded-2xl border border-black/10 bg-white p-6 md:p-10">
    <h2
      id="newsletter-title"
      class="font-heading text-2xl font-bold uppercase tracking-wide text-black md:text-3xl"
    >
      Join My Weekly Newsletter
    </h2>
    <p class="mt-3 font-body text-base text-black/70">
      Get Insights on AI, Tech & Education
    </p>

    <form action="#" method="post" class="mt-6 flex flex-col gap-3 sm:flex-row sm:items-start">
      <div class="flex-1">
        <label class="sr-only" for="newsletter-email">
          Email address
        </label>
        <input
          id="newsletter-email"
          name="email"
          type="email"
          inputmode="email"
          autocomplete="email"
          placeholder={placeholderEmail}
          required
          class="w-full rounded-md border border-black/15 bg-white px-4 py-3 font-body text-sm text-black placeholder:text-black/40 focus:outline-none focus:ring-0"
        />
      </div>

      <button
        type="submit"
        class="inline-flex items-center justify-center rounded-md bg-accent px-5 py-3 font-body text-sm font-bold uppercase tracking-wide text-white hover:opacity-90"
      >
        Subscribe
      </button>
    </form>

    <p class="mt-4 font-body text-sm text-black/60">
      This form UI is ready for your newsletter provider. It currently submits UI-only placeholders until you connect the backend.
    </p>
  </div>
</section>

